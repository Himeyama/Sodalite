<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="SDApp.Views.ModelSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SDApp.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="ModelSelectionDialog"
    DefaultButton="Close"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" MinWidth="420" MinHeight="320">
        <TextBlock Grid.Row="0" x:Uid="ModelSelectionDialog_Description"
                   Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"
                   Margin="0,0,0,8" TextWrapping="Wrap" />

        <InfoBar Grid.Row="1" x:Name="ErrorInfoBar" Severity="Error" IsOpen="False"
                 Margin="0,0,0,8" />

        <ProgressRing Grid.Row="2" x:Name="LoadingProgressRing" IsActive="False"
                      HorizontalAlignment="Left" Width="24" Height="24" Margin="0,0,0,8" />

        <ListView Grid.Row="3" x:Name="ModelListView"
                  SelectionMode="Single" SelectionChanged="ModelListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ModelListItem">
                    <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                        <TextBlock Grid.Column="0" Text="{x:Bind DisplayName}" VerticalAlignment="Center"
                                   ToolTipService.ToolTip="{x:Bind ModelId}" />
                        <FontIcon Grid.Column="1" Glyph="&#xE73E;" FontSize="14"
                                  VerticalAlignment="Center" Visibility="{x:Bind ActiveVisibility}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="4" x:Uid="ModelSelectionDialog_ImportButton"
                HorizontalAlignment="Stretch" Margin="0,8,0,0"
                Click="ImportButton_Click" />
    </Grid>
</ContentDialog>
