<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SDApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SDApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SDApp"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="48" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="8">
                <FontIcon Glyph="&#xE91B;" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="SDApp" Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusBarTextBlock" Grid.Column="0" Text="Ready"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                <TextBlock x:Name="StatusBarDeviceInfoTextBlock" Grid.Column="1"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" />
            </Grid>
        </Border>
    </Grid>
</Window>
