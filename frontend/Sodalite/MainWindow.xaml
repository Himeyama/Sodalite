<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Sodalite.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Sodalite"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="MainWindow"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="48" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="8">
                <Image Source="ms-appx:///Assets/AppIcon.ico" Width="16" Height="16"
                       VerticalAlignment="Center" />
                <TextBlock x:Uid="MainWindow_TitleBarText" Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <Border x:Name="SetupOverlay" Grid.Row="1" Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="560" Spacing="16" Padding="24">
                <ProgressRing IsActive="True" Width="48" Height="48"
                              HorizontalAlignment="Center" />
                <TextBlock x:Uid="SetupOverlay_Title" HorizontalAlignment="Center"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="SetupOverlay_Description" HorizontalAlignment="Center"
                           Style="{ThemeResource BodyTextBlockStyle}" Opacity="0.7"
                           TextAlignment="Center" TextWrapping="Wrap" />
                <TextBlock x:Name="SetupLogTextBlock" HorizontalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"
                           FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusBarTextBlock" Grid.Column="0"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                <HyperlinkButton x:Name="ModelSelectionButton" Grid.Column="1"
                                 Padding="0" IsEnabled="False" Click="ModelSelectionButton_Click">
                    <TextBlock x:Name="StatusBarDeviceInfoTextBlock"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" />
                </HyperlinkButton>
            </Grid>
        </Border>
    </Grid>
</Window>
